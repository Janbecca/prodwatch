<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }}</title>
    <style>
      body { font-family: Arial, "PingFang SC", "Microsoft YaHei", sans-serif; margin: 24px; }
      h1 { margin: 0 0 8px; }
      .meta { color: #555; margin-bottom: 16px; }
      .card { border: 1px solid #e5e7eb; border-radius: 10px; padding: 12px 14px; margin: 12px 0; }
      table { width: 100%; border-collapse: collapse; margin-top: 8px; }
      th, td { border: 1px solid #e5e7eb; padding: 8px; font-size: 12px; text-align: left; vertical-align: top; }
      th { background: #f9fafb; }
      .tag { display:inline-block; padding:2px 6px; border-radius: 999px; font-size: 12px; }
      .neg { background:#fee2e2; color:#991b1b; }
      .pos { background:#dcfce7; color:#166534; }
      .neu { background:#e5e7eb; color:#111827; }
    </style>
  </head>
  <body>
    <h1>{{ title }}</h1>
    <div class="meta">生成时间：{{ generated_at }}</div>

    <div class="card">
      <strong>摘要</strong>
      <div style="margin-top:6px">{{ summary }}</div>
    </div>

    {% if metrics %}
    <div class="card">
      <strong>指标（最近一天）</strong>
      <table>
        <thead>
          <tr>
            <th>平台</th>
            <th>总量</th>
            <th>有效</th>
            <th>水军</th>
            <th>正向</th>
            <th>中性</th>
            <th>负向</th>
          </tr>
        </thead>
        <tbody>
          {% for m in metrics %}
          <tr>
            <td>{{ m.platform }}</td>
            <td>{{ m.total_posts }}</td>
            <td>{{ m.valid_posts }}</td>
            <td>{{ m.spam_posts }}</td>
            <td>{{ m.pos_posts }}</td>
            <td>{{ m.neu_posts }}</td>
            <td>{{ m.neg_posts }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}

    {% if samples %}
    <div class="card">
      <strong>样本（Top {{ samples|length }})</strong>
      <table>
        <thead>
          <tr>
            <th>内容</th>
            <th>情感</th>
          </tr>
        </thead>
        <tbody>
          {% for s in samples %}
          <tr>
            <td>{{ s.clean_text }}</td>
            <td>
              {% if s.polarity == "negative" %}
                <span class="tag neg">负向</span>
              {% elif s.polarity == "positive" %}
                <span class="tag pos">正向</span>
              {% else %}
                <span class="tag neu">中性</span>
              {% endif %}
              ({{ s.polarity }})
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}
  </body>
</html>

